{
  "name": "@9h/webmidi",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "tasks": {
    "build:bindings": "cd bindings/midi && cargo build --release",
    "bindings": "cd bindings/midi && deno_bindgen --release --lazy-init -o mod.ts",
    "test": "MIDI_BINARY_PATH=$(pwd)/bindings/midi/target/release/libmidi.dylib deno run --allow-ffi --allow-env --allow-read midi_test.ts",
    "test:integration": "./test/integration/run.sh"
  },
  "license": "MIT",
  "publish": {
    "exclude": ["midi_test.ts", "test/"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@types/webmidi": "npm:@types/webmidi"
  }
}
